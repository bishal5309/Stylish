<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <Transition
        app:constraintSetEnd="@+id/end"
        app:constraintSetStart="@+id/start"
        app:duration="400">
    </Transition>

    <ConstraintSet android:id="@+id/start">
        <Constraint
            android:id="@+id/btn_menu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <Constraint
            android:id="@+id/header_profile"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:alpha="1"
            android:visibility="visible"
            app:layout_constraintTop_toTopOf="@+id/btn_menu"
            app:layout_constraintBottom_toBottomOf="@+id/btn_menu"
            app:layout_constraintEnd_toEndOf="parent" />

        <Constraint
            android:id="@+id/header_logo"
            android:layout_width="140dp"
            android:layout_height="45dp"
            android:alpha="1"
            android:visibility="visible"
            app:layout_constraintTop_toTopOf="@+id/btn_menu"
            app:layout_constraintBottom_toBottomOf="@+id/btn_menu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Constraint
            android:id="@+id/search_card_view"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            app:layout_constraintTop_toBottomOf="@+id/header_logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Constraint
            android:id="@+id/sticky_item_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/search_card_view" />

        <Constraint
            android:id="@+id/bottom_sort_filter_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:alpha="1"
            android:visibility="visible"
            app:layout_constraintTop_toBottomOf="@+id/search_card_view"
            app:layout_constraintBottom_toBottomOf="parent" />

        <Constraint
            android:id="@+id/sticky_actions_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@+id/btn_menu"
            app:layout_constraintBottom_toBottomOf="@+id/btn_menu"
            app:layout_constraintEnd_toEndOf="parent" />
    </ConstraintSet>


    <ConstraintSet android:id="@+id/end">

        <Constraint
            android:id="@+id/btn_menu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <Constraint
            android:id="@+id/header_profile"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0"
            app:layout_constraintTop_toTopOf="@+id/btn_menu"
            app:layout_constraintBottom_toBottomOf="@+id/btn_menu"
            app:layout_constraintEnd_toEndOf="parent" />

        <Constraint
            android:id="@+id/header_logo"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0"
            app:layout_constraintTop_toTopOf="@+id/btn_menu"
            app:layout_constraintBottom_toBottomOf="@+id/btn_menu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Constraint
            android:id="@+id/sticky_actions_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="1"
            android:visibility="visible"
            app:layout_constraintTop_toTopOf="@+id/btn_menu"
            app:layout_constraintBottom_toBottomOf="@+id/btn_menu"
            app:layout_constraintEnd_toEndOf="parent">
        </Constraint>

        <Constraint
            android:id="@+id/search_card_view"
            android:layout_width="0dp"
            android:layout_height="53dp"
            android:layout_marginStart="11dp"
            android:layout_marginEnd="11dp"
            app:layout_constraintTop_toTopOf="@+id/btn_menu"
            app:layout_constraintBottom_toBottomOf="@+id/btn_menu"
            app:layout_constraintStart_toEndOf="@+id/btn_menu"
            app:layout_constraintEnd_toStartOf="@+id/sticky_actions_layout" />

        <Constraint
            android:id="@+id/sticky_item_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/search_card_view" />

        <Constraint
            android:id="@+id/bottom_sort_filter_layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:alpha="0"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/sticky_item_count" />

    </ConstraintSet>
</MotionScene>