<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.motion.widget.MotionLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/top_header_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingBottom="10dp"
    android:background="#FDFDFD"
    android:clipChildren="false"
    android:clipToPadding="false"
    app:layoutDescription="@xml/header_scene">

    <ImageView
        android:id="@+id/btn_menu"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_menu"
        app:tint="#050505" />

    <ImageView
        android:id="@+id/header_logo"
        android:layout_width="140dp"
        android:layout_height="45dp"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_img" />

    <androidx.cardview.widget.CardView
        android:id="@+id/header_profile"
        android:layout_width="38dp"
        android:layout_height="38dp"
        app:cardCornerRadius="19dp"
        app:cardElevation="2dp">
        <ImageView
            android:id="@+id/profile_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/search_card_view"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginHorizontal="8dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="10dp"
        app:cardElevation="3dp"
        app:cardUseCompatPadding="true">
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/search_input_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:boxBackgroundColor="@android:color/transparent"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:endIconDrawable="@drawable/ic_mic"
            app:endIconMode="custom"
            app:endIconTint="#A0A0A0"
            app:hintEnabled="false"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="#A0A0A0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="Search any Product.."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:padding="0dp"
                android:textColorHint="#A0A0A0"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/sticky_item_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="200+ Items in Mens"
        android:textColor="#000000"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#FDFDFD"
        android:visibility="gone" />

    <RelativeLayout
        android:id="@+id/bottom_sort_filter_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="0dp"
        android:paddingBottom="5dp"
        android:clipChildren="false">

        <TextView
            android:id="@+id/tv_featured_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="All Featured"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal"
            android:clipChildren="false">

            <LinearLayout
                android:id="@+id/btn_sort"
                android:elevation="2dp"
                android:layout_margin="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_white"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sort"
                    android:textColor="#000000"
                    android:textSize="13sp" />
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_up_down_arrow"
                    app:tint="#000000" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_filter"
                android:elevation="2dp"
                android:layout_margin="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_white"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filter"
                    android:textColor="#000000"
                    android:textSize="13sp" />
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_filter"
                    app:tint="#000000" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/sticky_actions_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:clipChildren="false"
        android:clipToPadding="false">

        <ImageView
            android:id="@+id/sticky_btn_sort"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="10dp"
            android:layout_marginEnd="8dp"
            android:layout_marginVertical="5dp"
            android:layout_marginStart="5dp"
            android:background="@drawable/bg_rounded_white"
            android:elevation="3dp"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:src="@drawable/ic_up_down_arrow"
            app:tint="#000000" />

        <ImageView
            android:id="@+id/sticky_btn_filter"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="10dp"
            android:layout_marginVertical="5dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_rounded_white"
            android:elevation="3dp"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:src="@drawable/ic_filter"
            app:tint="#000000" />
    </LinearLayout>

</androidx.constraintlayout.motion.widget.MotionLayout>